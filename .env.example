# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=bof_crm
POSTGRES_USER=postgres
# IMPORTANT: use a strong random password in production
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── JWT secrets ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_64_CHARS

# ─── JWT expiry ───────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SSL (used by scripts/init-ssl.sh) ────────────────────────────────────────
SSL_EMAIL=admin@bofcrm.uz
