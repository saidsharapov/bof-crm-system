# Local development only — in production all vars come from docker-compose + root .env
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5435/bof_crm
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
